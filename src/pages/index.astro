---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="fr"
  title="Rémi Forte"
  description="Programme poétique, systèmes typographiques, design graphique et code."
  path="/fr/"
  alternatePaths={{ "x-default": "/fr/", fr: "/fr/", en: "/en/" }}
  refreshPath="/fr/"
>
  <main class="grid min-h-dvh place-items-center px-5 py-16 text-center">
    <div class="max-w-sm">
      <h1 class="text-base text-neutral-50">Rémi Forte</h1>
      <p class="mt-4 text-base text-neutral-50">Redirection vers la version française.</p>
      <p class="mt-4">
        <a class="text-base text-neutral-50 underline decoration-neutral-50" href="/fr/">Continuer vers /fr/</a>
      </p>
    </div>
  </main>
</BaseLayout>
