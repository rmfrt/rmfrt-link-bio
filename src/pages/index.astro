---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rémi Forte"
  description="Poetic program, typographic systems, graphic design, and code."
  path="/en/"
  refreshPath="/en/"
>
  <main class="grid min-h-dvh place-items-center px-5 py-16 text-center">
    <div class="max-w-sm">
      <h1 class="text-base text-neutral-50">Rémi Forte</h1>
      <p class="mt-4 text-base text-neutral-50">Redirecting to the English version.</p>
      <p class="mt-4">
        <a class="text-base text-neutral-50 underline decoration-neutral-50" href="/en/">Continue to /en/</a>
      </p>
    </div>
  </main>
</BaseLayout>
