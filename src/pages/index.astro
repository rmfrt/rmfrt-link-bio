---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeLinks from "../components/HomeLinks.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { homeContent } from "../data/i18n";
---

<BaseLayout title={homeContent.title} description={homeContent.description} path="/">
  <SiteHeader />
  <main class="mx-auto grid w-full max-w-2xl gap-12 px-5 pb-20 pt-12 sm:px-8 sm:pt-20">
    <h1 class="sr-only">Rémi Forte</h1>
    <p class="max-w-2xl text-left text-base text-neutral-50">{homeContent.intro}</p>
    <HomeLinks />
  </main>
</BaseLayout>
