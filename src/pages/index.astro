---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="fr"
  title="Rémi Forte"
  description="Programme poétique, systèmes typographiques, design graphique et code."
  path="/"
  alternatePaths={{ "x-default": "/fr/", fr: "/fr/", en: "/en/" }}
  refreshPath="/fr/"
>
  <main class="grid min-h-dvh place-items-center px-5 py-16 text-center">
    <div class="max-w-sm">
      <p class="text-sm text-muted">Redirection vers la version française.</p>
      <p class="mt-4">
        <a class="text-paper underline decoration-accent hover:text-accent" href="/fr/">Continuer vers preview.rmfrt.xyz/fr</a>
      </p>
    </div>
  </main>
</BaseLayout>
