---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found — Rémi Forte"
  description="This page does not exist."
  path="/404/"
>
  <main class="grid min-h-dvh place-items-center px-5 py-16">
    <div class="max-w-md">
      <p class="text-base text-neutral-50">404</p>
      <h1 class="mt-4 text-base text-neutral-50">Page not found</h1>
      <p class="mt-4 text-base text-neutral-50">The requested page does not exist or has moved.</p>
      <a class="mt-8 inline-flex border border-neutral-50/25 px-4 py-3 text-base text-neutral-50 hover:border-neutral-50" href="/">
        Back home
      </a>
    </div>
  </main>
</BaseLayout>
