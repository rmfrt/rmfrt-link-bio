---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="fr"
  title="Page introuvable — Rémi Forte"
  description="Cette page n'existe pas."
  path="/404/"
  alternatePaths={{ "x-default": "/fr/", fr: "/fr/", en: "/en/" }}
>
  <main class="grid min-h-dvh place-items-center px-5 py-16">
    <div class="max-w-md">
      <p class="text-base text-neutral-50">404</p>
      <h1 class="mt-4 text-base text-neutral-50">Page introuvable</h1>
      <p class="mt-4 text-base text-neutral-50">La page demandée n’existe pas ou a été déplacée.</p>
      <a class="mt-8 inline-flex border border-neutral-50/25 px-4 py-3 text-base text-neutral-50 hover:border-neutral-50" href="/fr/">
        Retour à l’accueil
      </a>
    </div>
  </main>
</BaseLayout>
