---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="fr"
  title="Page introuvable — Rémi Forte"
  description="Cette page n'existe pas."
  path="/404/"
  alternatePaths={{ "x-default": "/fr/", fr: "/fr/", en: "/en/" }}
>
  <main class="grid min-h-dvh place-items-center px-5 py-16">
    <div class="max-w-md">
      <p class="text-sm font-semibold tracking-[0.16em] text-warm uppercase">404</p>
      <h1 class="mt-4 text-4xl font-semibold text-paper">Page introuvable</h1>
      <p class="mt-4 text-muted">La page demandée n’existe pas ou a été déplacée.</p>
      <a class="mt-8 inline-flex rounded-lg border border-line px-4 py-3 text-paper hover:border-accent" href="/fr/">
        Retour à l’accueil
      </a>
    </div>
  </main>
</BaseLayout>
