---
import ResumeEntry from "../../../components/ResumeEntry.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import { resumeContent } from "../../../data/i18n";
import { resumeSections } from "../../../data/resume";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  locale="en"
  title={resumeContent.title}
  description={resumeContent.description}
  path="/en/resume/"
  alternatePaths={{ en: "/en/resume/", "x-default": "/en/resume/" }}
>
  <SiteHeader locale="en" activePath="/en/resume/" />
  <main class="mx-auto w-full max-w-4xl px-5 pb-24 pt-10 sm:px-8 sm:pt-16">
    <section class="max-w-3xl">
      <p class="text-sm font-semibold tracking-[0.16em] text-warm uppercase">{resumeContent.eyebrow}</p>
      <h1 class="mt-5 text-5xl font-semibold leading-none text-paper sm:text-7xl">{resumeContent.heading}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted sm:text-xl">{resumeContent.intro}</p>
    </section>

    <div class="mt-16 grid gap-16">
      {
        resumeSections.map((section) => (
          <section aria-labelledby={`resume-${section.title.toLowerCase().replaceAll(" ", "-")}`}>
            <h2
              id={`resume-${section.title.toLowerCase().replaceAll(" ", "-")}`}
              class="mb-2 text-xs font-semibold tracking-[0.16em] text-accent uppercase"
            >
              {section.title}
            </h2>
            <div>{section.items.map((item) => <ResumeEntry item={item} />)}</div>
          </section>
        ))
      }
    </div>
  </main>
</BaseLayout>
