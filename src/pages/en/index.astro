---
import HomeLinks from "../../components/HomeLinks.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { homeContent } from "../../data/i18n";
import BaseLayout from "../../layouts/BaseLayout.astro";

const locale = "en";
const content = homeContent[locale];
---

<BaseLayout locale={locale} title={content.title} description={content.description} path="/en/">
  <SiteHeader locale={locale} activePath="/en/" />
  <main class="mx-auto grid w-full max-w-3xl gap-12 px-5 pb-20 pt-12 sm:px-8 sm:pt-20">
    <section class="max-w-2xl">
      <p class="text-sm font-semibold tracking-[0.16em] text-warm uppercase">{content.eyebrow}</p>
      <h1 class="mt-5 text-5xl font-semibold leading-none text-paper sm:text-7xl">Rémi Forte</h1>
      <p class="mt-6 max-w-xl text-xl leading-8 text-muted sm:text-2xl sm:leading-9">{content.lede}</p>
    </section>
    <HomeLinks locale={locale} primaryLabel={content.primaryLabel} secondaryLabel={content.secondaryLabel} />
  </main>
</BaseLayout>
