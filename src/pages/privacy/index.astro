---
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Rémi Forte — Privacy"
  description="Privacy notice for rmfrt.com."
  path="/privacy/"
>
  <SiteHeader />
  <main class="mx-auto w-full max-w-2xl px-5 pb-20 pt-10 sm:px-8 sm:pt-16">
    <h1 class="mb-12 text-base text-neutral-50">Privacy</h1>

    <div class="grid gap-8 text-base text-neutral-50">
      <section aria-labelledby="privacy-analytics">
        <h2 id="privacy-analytics" class="text-base text-neutral-50">Analytics</h2>
        <div class="mt-4 grid gap-4">
          <p>
            This site uses self-hosted Umami Analytics for aggregate traffic
            measurement, without cookies, advertising tracking, or cross-site
            tracking. Analytics data is not used to identify individual visitors.
          </p>
        </div>
      </section>

      <section aria-labelledby="privacy-contact">
        <h2 id="privacy-contact" class="text-base text-neutral-50">Contact</h2>
        <p class="mt-4">
          For any privacy question,
          <button
            type="button"
            data-email-link
            aria-label="Email Rémi Forte"
            class="cursor-pointer text-base text-neutral-50 underline decoration-neutral-50"
          >
            contact me by email
          </button>
          .
        </p>
      </section>
    </div>

    <script>
      const emailLinks = document.querySelectorAll("[data-email-link]");
      const mailtoPrefix = [109, 97, 105, 108, 116, 111, 58];
      const emailAddress = [105, 110, 102, 111, 64, 114, 109, 102, 114, 116, 46, 99, 111, 109];
      const decode = (values: number[]) => String.fromCharCode(...values);

      emailLinks.forEach((link) => {
        link.addEventListener("click", () => {
          window.location.href = `${decode(mailtoPrefix)}${decode(emailAddress)}`;
        });
      });
    </script>
  </main>
  <SiteFooter />
</BaseLayout>
