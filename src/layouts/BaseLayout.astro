---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";
import { absoluteUrl, siteIdentity, siteNoindex, type Locale } from "../data/site";

type AlternatePaths = Partial<Record<Locale | "x-default", string>>;

interface Props {
  locale: Locale;
  title: string;
  description: string;
  path: string;
  alternatePaths?: AlternatePaths;
  image?: string;
  imageAlt?: string;
  refreshPath?: string;
}

const {
  locale,
  title,
  description,
  path,
  alternatePaths = { fr: "/fr/", en: "/en/", "x-default": "/fr/" },
  image = siteIdentity.ogImage,
  imageAlt = siteIdentity.ogImageAlt,
  refreshPath
} = Astro.props;

const canonical = absoluteUrl(path);
const imageUrl = absoluteUrl(image);
const alternates = Object.entries(alternatePaths).filter((entry): entry is [string, string] => Boolean(entry[1]));
const ogLocale = locale === "fr" ? "fr_FR" : "en_US";
const alternateOgLocale = locale === "fr" ? "en_US" : "fr_FR";
const hasAlternateOgLocale = locale === "fr" ? Boolean(alternatePaths.en) : Boolean(alternatePaths.fr);
const robots = siteNoindex ? "noindex,nofollow,noarchive" : "index,follow";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical} />
    {alternates.map(([lang, href]) => <link rel="alternate" hreflang={lang} href={absoluteUrl(href)} />)}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    {hasAlternateOgLocale && <meta property="og:locale:alternate" content={alternateOgLocale} />}
    <meta property="og:site_name" content={siteIdentity.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(siteIdentity.ogImageWidth)} />
    <meta property="og:image:height" content={String(siteIdentity.ogImageHeight)} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="preload" href="/fonts/MuotoVF.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {refreshPath && <meta http-equiv="refresh" content={`0;url=${refreshPath}`} />}
    <Analytics />
  </head>
  <body class="bg-neutral-950 text-base text-neutral-50">
    <slot />
  </body>
</html>
