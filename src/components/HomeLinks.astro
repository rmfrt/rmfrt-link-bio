---
import { isExternalUrl, primaryLinks, secondaryLinks } from "../data/links";

const links = [...primaryLinks, ...secondaryLinks];
const itemClass =
  "group grid h-16 cursor-pointer place-items-center border border-neutral-50 px-4 py-3 transition-colors duration-150 hover:bg-neutral-50 focus-visible:bg-neutral-50";
const labelClass = "text-center text-xl text-neutral-50 transition-colors duration-150 group-hover:text-neutral-950 group-focus-visible:text-neutral-950";
const navLabel = "Links";
const emailAriaLabel = "Email Rémi Forte";
const externalLabelSuffix = " (opens in a new tab)";

function getLinkAriaLabel(link: (typeof links)[number]): string | undefined {
  if (!link.href || !isExternalUrl(link.href)) {
    return undefined;
  }

  return `${link.label}${externalLabelSuffix}`;
}
---

<nav aria-label={navLabel}>
  <div class="grid gap-2">
    {
      links.map((link) =>
        link.kind === "email" ? (
          <button type="button" data-email-link class={itemClass} aria-label={emailAriaLabel}>
            <span class={labelClass}>{link.label}</span>
          </button>
        ) : (
          <a
            href={link.href}
            target={link.href && isExternalUrl(link.href) ? "_blank" : undefined}
            rel={link.href && isExternalUrl(link.href) ? ["noopener noreferrer", link.rel].filter(Boolean).join(" ") : undefined}
            class={itemClass}
            aria-label={getLinkAriaLabel(link)}
          >
            <span class={labelClass}>{link.label}</span>
          </a>
        )
      )
    }
  </div>
</nav>

<script>
  const emailLinks = document.querySelectorAll("[data-email-link]");
  const scheme = [109, 97, 105, 108, 116, 111, 58];
  const address = [105, 110, 102, 111, 64, 114, 109, 102, 114, 116, 46, 99, 111, 109];
  const toText = (codes: number[]) => String.fromCharCode(...codes);

  emailLinks.forEach((link) => {
    link.addEventListener("click", () => {
      window.location.href = `${toText(scheme)}${toText(address)}`;
    });
  });
</script>
