---
import type { ResumeItem } from "../data/resume";
import { formatDateRange, formatLocationHtml } from "../data/resume";
import { renderInlineMarkdown } from "../data/markdown";

interface Props {
  item: ResumeItem;
}

const { item } = Astro.props;
---

<article class="grid gap-2 border-t border-neutral-50/25 py-5 first:border-t-0 sm:grid-cols-[minmax(0,1fr)_9rem] sm:gap-5">
  <div class="min-w-0">
    <h3 class="text-base text-neutral-50" set:html={renderInlineMarkdown(item.what)}></h3>
    <p class="resume-location mt-1 text-base text-neutral-50" set:html={formatLocationHtml(item.where)}></p>
    {
      item.description && (
        <p class="rich-text mt-3 max-w-2xl text-base text-neutral-50" set:html={renderInlineMarkdown(item.description)}></p>
      )
    }
  </div>
  <p class="text-base text-neutral-50 sm:text-right">{formatDateRange(item.when)}</p>
</article>
