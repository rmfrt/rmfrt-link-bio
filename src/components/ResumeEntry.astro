---
import type { ResumeItem } from "../data/resume";
import { formatDateRangeParts, formatLocationHtml } from "../data/resume";
import { renderInlineMarkdown } from "../data/markdown";

interface Props {
  item: ResumeItem;
}

const { item } = Astro.props;
const dateRange = formatDateRangeParts(item.when);
---

<article class="border-t border-neutral-50/25 py-5 first:border-t-0">
  <h3 class="text-base text-neutral-50" set:html={renderInlineMarkdown(item.what)}></h3>
  <p class="resume-location text-base text-neutral-50" set:html={formatLocationHtml(item.where)}></p>
  {
    item.description && (
      <p class="rich-text text-base text-neutral-50" set:html={renderInlineMarkdown(item.description)}></p>
    )
  }
  <p class="text-base text-neutral-50">
    <time datetime={dateRange.start.dateTime}>{dateRange.start.label}</time>
    {dateRange.end && <><span aria-hidden="true">–</span><time datetime={dateRange.end.dateTime}>{dateRange.end.label}</time></>}
  </p>
</article>
